{
  "schemaVersion": 3,
  "metricRegistry": "./life-derived-metrics.json",
  "unknownMetricPolicy": "error",
  "selection": {
    "mode": "highest_priority_then_score_then_id",
    "deathCauseResolvedFirst": true,
    "primaryEndingCount": 1,
    "secondaryTagLimit": 6
  },
  "deathCauses": [
    { "id": "old_age", "priority": 100, "conditions": { "ageYearsMin": 80 } },
    { "id": "health_failure", "priority": 200, "conditions": { "metricMax": { "health": 0 } } },
    { "id": "illness", "priority": 150, "conditions": { "requiredTags": ["serious_illness"] } },
    { "id": "accident", "priority": 300, "conditions": { "requiredFlags": ["fatal_accident"] } },
    { "id": "other", "priority": 0, "conditions": {} }
  ],
  "primaryEndings": [
    { "id": "career_peak", "priority": 900, "score": { "achievement": 0.70, "legacy": 0.30 }, "conditions": { "metricMin": { "achievement": 82 } } },
    { "id": "financial_freedom", "priority": 880, "score": { "money": 0.75, "freedom": 0.25 }, "conditions": { "metricMin": { "money": 85, "freedom": 60 } } },
    { "id": "family_anchor", "priority": 840, "score": { "relationship": 0.75, "legacy": 0.25 }, "conditions": { "metricMin": { "relationship": 82 } } },
    { "id": "lifelong_love", "priority": 830, "score": { "relationship": 0.80, "health": 0.20 }, "conditions": { "metricMin": { "relationship": 88 }, "requiredTags": ["long_term_partner"] } },
    { "id": "creative_legacy", "priority": 820, "score": { "knowledge": 0.35, "legacy": 0.65 }, "conditions": { "metricMin": { "legacy": 75 }, "requiredTags": ["creator"] } },
    { "id": "public_contribution", "priority": 810, "score": { "contribution": 0.75, "legacy": 0.25 }, "conditions": { "metricMin": { "contribution": 80 } } },
    { "id": "free_spirit", "priority": 700, "score": { "freedom": 0.55, "adventure": 0.45 }, "conditions": { "metricMin": { "freedom": 70, "adventure": 65 } } },
    { "id": "second_chance", "priority": 690, "score": { "achievement": 0.30, "health": 0.25, "relationship": 0.25, "freedom": 0.20 }, "conditions": { "requiredTags": ["recovered"] } },
    { "id": "rise_and_fall", "priority": 650, "score": { "achievement": 0.45, "money": 0.35, "adventure": 0.20 }, "conditions": { "requiredTags": ["major_loss"] } },
    { "id": "debt_life", "priority": 640, "score": { "money": -0.70, "health": -0.30 }, "conditions": { "metricMax": { "money": 20 } } },
    { "id": "lonely_later_life", "priority": 630, "score": { "relationship": -0.75, "health": 0.25 }, "conditions": { "metricMax": { "relationship": 20 }, "ageYearsMin": 60 } },
    { "id": "unfinished_path", "priority": 620, "score": { "achievement": 0.50, "knowledge": 0.25, "adventure": 0.25 }, "conditions": { "ageYearsMax": 45 } },
    { "id": "ordinary_complete", "priority": 100, "score": { "health": 0.20, "relationship": 0.25, "achievement": 0.15, "money": 0.15, "freedom": 0.10, "legacy": 0.15 }, "conditions": {} },
    { "id": "hidden_rare", "priority": 1000, "score": { "legacy": 0.50, "knowledge": 0.25, "adventure": 0.25 }, "conditions": { "requiredFlags": ["hidden_ending_unlocked"] } }
  ],
  "secondaryTags": [
    { "id": "healthy_longevity", "conditions": { "ageYearsMin": 85, "metricMin": { "health": 65 } } },
    { "id": "family_harmony", "conditions": { "metricMin": { "relationship": 80 } } },
    { "id": "financially_secure", "conditions": { "metricMin": { "money": 75 } } },
    { "id": "adventurer", "conditions": { "metricMin": { "adventure": 75 } } },
    { "id": "lifelong_learner", "conditions": { "metricMin": { "knowledge": 80 } } },
    { "id": "public_legacy", "conditions": { "metricMin": { "contribution": 75, "legacy": 70 } } }
  ],
  "lifeScoreWeights": {
    "health": 0.15,
    "relationship": 0.20,
    "achievement": 0.15,
    "money": 0.10,
    "legacy": 0.15,
    "freedom": 0.10,
    "knowledge": 0.05,
    "contribution": 0.05,
    "adventure": 0.05
  }
}