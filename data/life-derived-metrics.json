{
  "schemaVersion": 3,
  "range": { "min": 0, "max": 100, "round": "nearest", "clamp": true },
  "unknownMetricPolicy": "error",
  "metrics": {
    "achievement": { "formula": "clamp(educationGrowth*0.20 + careerGrowth*0.25 + goalsCompleted*0.20 + reputation*0.15 + creativeWorks*0.20)" },
    "relationship": { "formula": "clamp(familyStability*0.35 + partnerSupport*0.35 + friendshipSupport*0.30)" },
    "health": { "formula": "clamp(stats.health*0.55 + stats.fitness*0.20 + (100-stats.stress)*0.25)" },
    "money": { "formula": "clamp(financialSecurity*0.50 + normalizedNetAssets*0.35 + incomeStability*0.15)" },
    "legacy": { "formula": "clamp(contribution*0.40 + peopleHelpedScore*0.25 + creativeLegacy*0.20 + familyLegacy*0.15)" },
    "freedom": { "formula": "clamp(freeTime*0.25 + financialSecurity*0.25 + autonomy*0.30 + lifeVariety*0.20)" },
    "knowledge": { "formula": "clamp(stats.smarts*0.35 + educationGrowth*0.40 + lifelongLearning*0.25)" },
    "contribution": { "formula": "clamp(publicContribution*0.50 + peopleHelpedScore*0.30 + stats.empathy*0.20)" },
    "adventure": { "formula": "clamp(lifeVariety*0.45 + riskTurnsScore*0.30 + regionVariety*0.25)" },

    "financialSecurity": { "formula": "clamp(normalizedNetAssets*0.45 + incomeStability*0.30 + (100-debtBurden)*0.25)" },
    "normalizedNetAssets": { "formula": "clamp(logNormalize(max(0, resources.assets-resources.debt), 0, 10000000))" },
    "incomeStability": { "formula": "clamp(profitableYearsRatio*100)" },
    "debtBurden": { "formula": "clamp(logNormalize(resources.debt, 0, 2000000))" },
    "wealth": { "formula": "normalizedNetAssets" },

    "businessSuccess": { "formula": "clamp(entrepreneurshipScore*0.35 + businessAssetScore*0.35 + profitableBusinessYearsRatio*30)" },
    "peopleHelped": { "formula": "countUniqueExperienceTag('helped_person')" },
    "peopleHelpedScore": { "formula": "clamp(peopleHelped*5)" },
    "familyStability": { "formula": "clamp(activeFamilyTrustMean*0.40 + activeFamilyClosenessMean*0.35 + (100-activeFamilyConflictMean)*0.25 - familyRuptureCount*10)" },
    "familyCloseness": { "formula": "clamp(activeFamilyClosenessMean)" },
    "familyLegacy": { "formula": "clamp(familyStability*0.70 + min(identity.childrenCount*10,30))" },
    "careYears": { "formula": "countExperienceTagWeeks('family_care')/52" },
    "partnerCloseness": { "formula": "lastLongTermPartner.closeness || 0" },
    "partnerSupport": { "formula": "clamp(lastLongTermPartner.closeness*0.45 + lastLongTermPartner.trust*0.40 + (100-lastLongTermPartner.conflict)*0.15)" },
    "relationshipYears": { "formula": "longTermPartnerWeeks/52" },
    "conflict": { "formula": "lastLongTermPartner.conflict || 0" },
    "friendCount": { "formula": "countRelationships(role='friend', status='active')" },
    "friendCloseness": { "formula": "meanRelationship('friend','closeness')" },
    "friendshipSupport": { "formula": "clamp(friendCloseness*0.70 + min(friendCount*5,30))" },
    "relationshipLosses": { "formula": "countExperienceTags(['relationship_loss','bereavement'])" },
    "loneliness": { "formula": "clamp(100-(partnerSupport*0.45+familyStability*0.30+friendshipSupport*0.25))" },

    "lifeVariety": { "formula": "clamp(uniqueExperienceTypeRatio*35 + uniqueCareerRatio*25 + uniqueRegionRatio*20 + uniqueMajorActivityRatio*20)" },
    "regionVariety": { "formula": "clamp(uniqueRegionRatio*100)" },
    "lateLifeGrowth": { "formula": "clamp(positiveDeltaAfterAge50(stats,resources,relationships))" },
    "turningPoints": { "formula": "countUniqueExperienceTag('turning_point')" },
    "unresolvedGoals": { "formula": "countActiveGoalsWithoutCompletion()" },
    "careerChanges": { "formula": "countUniqueExperienceTag('career_change')" },
    "educationEvents": { "formula": "countUniqueExperienceTag('education_growth')" },
    "educationGrowth": { "formula": "clamp(educationEvents*8)" },
    "careerGrowth": { "formula": "clamp(resources.careerLevel*10 + careerChanges*2)" },
    "riskTurns": { "formula": "countUniqueExperienceTag('risk_choice')" },
    "riskTurnsScore": { "formula": "clamp(riskTurns*8)" },
    "recoveryTurns": { "formula": "countUniqueExperienceTag('recovery')" },
    "peakWealth": { "formula": "clamp(logNormalize(maxTimelineNetAssets(),0,10000000))" },
    "largestLoss": { "formula": "clamp(maxPeakToTroughLossRatio()*100)" },
    "financialStress": { "formula": "clamp(stats.stress*0.60 + debtBurden*0.40)" },
    "bankruptcies": { "formula": "countUniqueExperienceTag('bankruptcy')" },
    "creativeWorks": { "formula": "countUniqueExperienceTag('creative_work')" },
    "creativeLegacy": { "formula": "clamp(creativeWorks*12 + reputationFromCreativeWork())" },
    "publicContribution": { "formula": "clamp(countUniqueExperienceTag('public_contribution')*10 + publicContributionMagnitude())" },
    "goalsCompleted": { "formula": "countUniqueExperienceTag('completed_goal')" },
    "lifelongLearning": { "formula": "clamp(educationEvents*10)" },
    "autonomy": { "formula": "clamp(100-dependencyPenalty())" },
    "freeTime": { "formula": "clamp(resources.freeTime)" },
    "reputation": { "formula": "clamp(resources.reputation)" },
    "hiddenEndingScore": { "formula": "flags.hidden_ending_unlocked ? 100 : 0" }
  }
}