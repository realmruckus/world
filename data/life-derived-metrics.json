{
  "schemaVersion": 3,
  "dsl": "./life-metric-dsl.json",
  "range": { "min": 0, "max": 100, "round": "nearest", "clamp": true },
  "unknownMetricPolicy": "error",
  "metrics": {
    "achievement": { "formula": "clamp(educationGrowth*0.20 + careerGrowth*0.25 + goalsCompleted*0.20 + reputation*0.15 + creativeWorksScore*0.20)" },
    "relationship": { "formula": "clamp(familyStability*0.35 + partnerSupport*0.35 + friendshipSupport*0.30)" },
    "health": { "formula": "clamp(health.health*0.55 + body.fitness*0.20 + (100-mind.stress)*0.25)" },
    "money": { "formula": "clamp(financialSecurity*0.50 + normalizedNetAssets*0.35 + incomeStability*0.15)" },
    "legacy": { "formula": "clamp(contribution*0.40 + peopleHelpedScore*0.25 + creativeLegacy*0.20 + familyLegacy*0.15)" },
    "freedom": { "formula": "clamp(freeTime*0.25 + financialSecurity*0.25 + autonomy*0.30 + lifeVariety*0.20)" },
    "knowledge": { "formula": "clamp(mind.smarts*0.35 + educationGrowth*0.40 + lifelongLearning*0.25)" },
    "contribution": { "formula": "clamp(publicContribution*0.50 + peopleHelpedScore*0.30 + mind.empathy*0.20)" },
    "adventure": { "formula": "clamp(lifeVariety*0.45 + riskTurnsScore*0.30 + regionVariety*0.25)" },
    "financialSecurity": { "formula": "clamp(normalizedNetAssets*0.45 + incomeStability*0.30 + (100-debtBurden)*0.25)" },
    "normalizedNetAssets": { "formula": "clamp(logNormalize(max(0,finance.assets-finance.debt),0,10000000))" },
    "incomeStability": { "formula": "clamp(profitableYearsRatio(history.timeline)*100)" },
    "debtBurden": { "formula": "clamp(logNormalize(finance.debt,0,2000000))" },
    "businessSuccess": { "formula": "clamp(entrepreneurshipScore(history.experiences)*0.35 + businessAssetScore(finance)*0.35 + profitableBusinessYearsRatio(history.timeline)*30)" },
    "peopleHelped": { "formula": "countUniqueExperienceTag(history.experiences,'helped_person')" },
    "peopleHelpedScore": { "formula": "clamp(peopleHelped*5)" },
    "familyStability": { "formula": "clamp(meanDimension(relationships,'family','trust')*0.40 + meanDimension(relationships,'family','love')*0.35 + (100-meanDimension(relationships,'family','conflict'))*0.25 - countRelationshipRuptures(relationships,'family')*10)" },
    "familyLegacy": { "formula": "clamp(familyStability*0.70 + min(identity.childrenCount*10,30))" },
    "partnerSupport": { "formula": "clamp(meanDimension(relationships,'partner','love')*0.35 + meanDimension(relationships,'partner','trust')*0.30 + meanDimension(relationships,'partner','respect')*0.20 + (100-meanDimension(relationships,'partner','conflict'))*0.15)" },
    "friendCount": { "formula": "countRelationships(relationships,'friend','active')" },
    "friendshipSupport": { "formula": "clamp(meanDimension(relationships,'friend','trust')*0.40 + meanDimension(relationships,'friend','love')*0.30 + meanDimension(relationships,'friend','respect')*0.20 + min(friendCount*2,10))" },
    "lifeVariety": { "formula": "clamp(uniqueExperienceTypeRatio(history.experiences)*35 + uniqueCareerRatio(history.timeline)*25 + uniqueRegionRatio(history.timeline)*20 + uniqueMajorActivityRatio(history.experiences)*20)" },
    "regionVariety": { "formula": "clamp(uniqueRegionRatio(history.timeline)*100)" },
    "educationGrowth": { "formula": "clamp(countUniqueExperienceTag(history.experiences,'education_growth')*8)" },
    "careerGrowth": { "formula": "clamp(career.level*10 + countUniqueExperienceTag(history.experiences,'career_change')*2)" },
    "riskTurnsScore": { "formula": "clamp(countUniqueExperienceTag(history.experiences,'risk_choice')*8)" },
    "creativeWorksScore": { "formula": "clamp(countUniqueExperienceTag(history.experiences,'creative_work')*12)" },
    "creativeLegacy": { "formula": "clamp(creativeWorksScore + reputationFromCreativeWork(history.experiences,finance.reputation))" },
    "publicContribution": { "formula": "clamp(countUniqueExperienceTag(history.experiences,'public_contribution')*10 + publicContributionMagnitude(history.experiences))" },
    "goalsCompleted": { "formula": "countUniqueExperienceTag(history.experiences,'completed_goal')" },
    "lifelongLearning": { "formula": "clamp(countUniqueExperienceTag(history.experiences,'education_growth')*10)" },
    "autonomy": { "formula": "clamp(100-dependencyPenalty(relationships,finance))" },
    "freeTime": { "formula": "clamp(career.freeTime)" },
    "reputation": { "formula": "clamp(finance.reputation)" }
  }
}